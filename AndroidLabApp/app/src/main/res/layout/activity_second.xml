<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for SecondActivity - demonstrates receiving intent data -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Second Activity"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvReceivedData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Received data will appear here"
        android:textSize="18sp"
        android:padding="16dp"
        android:background="#E3F2FD"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Type reply to send back"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSendBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Reply & Go Back" />

</LinearLayout>
