<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for MenuActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu Demo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Options Menu → Use the 3-dot menu at top right"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvContextTarget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Long-press here for Context Menu"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="#E8F5E9"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnPopupMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Show Popup Menu"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvMenuResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Menu result will appear here..."
        android:textSize="16sp"
        android:padding="12dp"
        android:background="#FFF3E0"
        android:textColor="#E65100" />

</LinearLayout>
