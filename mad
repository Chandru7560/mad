package com.example.modellab

import android.widget.Button
import android.widget.TextView
import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import android.os.Build
import androidx.core.app.NotificationCompat
import androidx.core.app.NotificationManagerCompat
import android.app.NotificationChannel
import android.app.NotificationManager
import android.content.Context

class CartActivity : AppCompatActivity() {

    lateinit var db: DBHelper

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_cart)

        db = DBHelper(this)

        val txtItems = findViewById<TextView>(R.id.txtItems)
        val txtTotal = findViewById<TextView>(R.id.txtTotal)
        val btnCheckout = findViewById<Button>(R.id.btnCheckout)

        // 🔹 Get data from SQLite
        val data = db.getAllItems()
        txtItems.text = data.first
        txtTotal.text = "Total: ${data.second}"

        btnCheckout.setOnClickListener {
            txtItems.text = "Ordered Successfully!"

            // 🔹 Clear database after order
            db.clearCart()

            showNotification()
        }
    }

    private fun showNotification() {
        val channelId = "OrderId"

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                channelId,
                "Order Notification",
                NotificationManager.IMPORTANCE_DEFAULT
            )

            val manager = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
            manager.createNotificationChannel(channel)
        }

        val builder = NotificationCompat.Builder(this, channelId)
            .setSmallIcon(android.R.drawable.ic_dialog_info)
            .setContentTitle("Order")
            .setContentText("Your order has been successfully ordered!")
            .setPriority(NotificationCompat.PRIORITY_DEFAULT)
            .setAutoCancel(true)

        NotificationManagerCompat.from(this).notify(1, builder.build())
    }
}



