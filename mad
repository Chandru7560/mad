package com.example.audioplayer

import android.media.MediaPlayer
import androidx.appcompat.app.AppCompatActivity
import android.os.Bundle
import android.widget.Button
import android.widget.Toast

class MainActivity : AppCompatActivity() {

    lateinit var song1: Button
    lateinit var song2: Button
    lateinit var song3: Button
    lateinit var stop: Button

    var mediaPlayer: MediaPlayer? = null

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        song1 = findViewById(R.id.song1Btn)
        song2 = findViewById(R.id.song2Btn)
        song3 = findViewById(R.id.song3Btn)
        stop = findViewById(R.id.stopBtn)

        song1.setOnClickListener {
            playAudio(R.raw.song1)
            Toast.makeText(this, "Playing Song 1", Toast.LENGTH_SHORT).show()
        }

        song2.setOnClickListener {
            playAudio(R.raw.song2)
            Toast.makeText(this, "Playing Song 2", Toast.LENGTH_SHORT).show()
        }

        song3.setOnClickListener {
            playAudio(R.raw.song3)
            Toast.makeText(this, "Playing Song 3", Toast.LENGTH_SHORT).show()
        }

        stop.setOnClickListener {
            stopAudio()
            Toast.makeText(this, "Audio Stopped", Toast.LENGTH_SHORT).show()
        }
    }

    private fun playAudio(resId: Int) {
        stopAudio() // stop previous song if playing
        mediaPlayer = MediaPlayer.create(this, resId)
        mediaPlayer?.start()
    }

    private fun stopAudio() {
        if (mediaPlayer != null) {
            if (mediaPlayer!!.isPlaying) {
                mediaPlayer!!.stop()
            }
            mediaPlayer!!.release()
            mediaPlayer = null
        }
    }

    override fun onDestroy() {
        super.onDestroy()
        stopAudio()
    }
}

